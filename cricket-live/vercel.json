{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/build",
  "installCommand": "cd api && npm install",
  "functions": {
    "api/cricket.js": { "memory": 256, "maxDuration": 15 },
    "api/static.js":  { "memory": 128, "maxDuration": 5 }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "livecricketzone.com" }],
      "destination": "https://www.livecricketzone.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml",      "destination": "/api/static" },
    { "source": "/robots.txt",       "destination": "/api/static" },
    { "source": "/ads.txt",          "destination": "/api/static" },
    { "source": "/BingSiteAuth.xml", "destination": "/api/static" },
    { "source": "/api/health",               "destination": "/api/cricket" },
    { "source": "/api/matches/live",         "destination": "/api/cricket" },
    { "source": "/api/matches/upcoming",     "destination": "/api/cricket" },
    { "source": "/api/matches/schedule",     "destination": "/api/cricket" },
    { "source": "/api/matches/:id/scorecard","destination": "/api/cricket" },
    { "source": "/api/matches/:id/score",    "destination": "/api/cricket" },
    { "source": "/api/matches/:id",          "destination": "/api/cricket" },
    { "source": "/api/series/:id",           "destination": "/api/cricket" },
    { "source": "/api/series",               "destination": "/api/cricket" },
    { "source": "/api/players/:id",          "destination": "/api/cricket" },
    { "source": "/api/players",              "destination": "/api/cricket" },
    { "source": "/api/news",                 "destination": "/api/cricket" },
    { "source": "/api/teams",                "destination": "/api/cricket" },
    { "source": "/api/rankings",             "destination": "/api/cricket" },
    { "source": "/(.*)",                     "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS" }
      ]
    }
  ]
}
