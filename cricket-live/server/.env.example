# Get free API key from https://cricketdata.org (sign up free)
CRICAPI_KEY=your_cricketdata_org_api_key_here

# Get free key from https://rapidapi.com/Creativesdev/api/free-cricbuzz-cricket-api
RAPIDAPI_KEY=your_rapidapi_key_here

# Get free YouTube Data API v3 key from https://console.cloud.google.com
# Free quota: 10,000 units/day — search costs 100 units per call
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

PORT=5000
